{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "TaskFlow - Aplicación web moderna de gestión de tareas. Proyecto académico PA2 - Construcción de Software.",
  "main": "src/js/app.js",
  "scripts": {
    "test": "jest --coverage",
    "lint": "eslint src/js/**/*.js",
    "lint:fix": "eslint src/js/**/*.js --fix",
    "start": "npx serve src",
    "build": "echo 'Build completado - archivos estáticos listos en /src'"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "src/js/**/*.js"
    ],
    "coverageThreshold": {
      "./src/js/storage.js": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [
    "taskflow",
    "todo",
    "javascript",
    "gitflow",
    "cicd"
  ],
  "author": "Abel Maldonado Vasquez",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0"
  }
}
